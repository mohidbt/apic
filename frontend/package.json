  "scripts": {
    "analyze": "cross-env ANALYZE=true next build",
    "build": "next build",
    "build-storybook": "storybook build",
    "clean": "node scripts/clean.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx scripts/seed.ts",
    "db:studio": "drizzle-kit studio",
    "dev": "next dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "setup": "node scripts/setup.js",
    "start": "next start",
    "storybook": "storybook dev -p 6006",
    "test": "vitest --config testing/vitest.config.ts",
    "test:coverage": "vitest --config testing/vitest.config.ts --coverage",
    "test:e2e": "playwright test --config testing/playwright.config.ts",
    "test:e2e:mobile": "playwright test --config testing/playwright.config.ts --project=mobile-chrome --project=mobile-safari",
    "test:e2e:mobile:visual": "playwright test --config testing/playwright.config.ts testing/tests/e2e/mobile-core-flows.spec.ts --grep \"visual layout remains stable\" --project=mobile-chrome --project=mobile-safari",
    "test:e2e:ui": "playwright test --config testing/playwright.config.ts --ui",
    "test:watch": "vitest --config testing/vitest.config.ts --watch",
    "type-check": "tsc --noEmit",
    "knip": "knip",
    "codehawk": "codehawk src"
  },
