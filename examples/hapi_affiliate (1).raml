      type: 2
      name: Boston
      fullName: Boston, Massachusetts, United States
      isSearchable: false
      latitude: 42.360903491390246
      longitude: -71.05889023544313
      hasBoundary: true
      radius: 0
      maximumRadius: 0
  HotelProvider:
    type: object
    description: Hotel provider details
    properties:
      code:
        type: string
        description: Provider code
      name:
        type: string
        description: Provider name
      logo:
        type: string
        description: URL to the provider's logo
      isDirect:
        type: boolean
        description: Indicates whether the provider is a direct provider. Direct providers are typically hotel chains
      isLanguageSupported:
        type: boolean
        description: Indicates whether the provider supports the requested language
      cashback?:
        type: ProviderCashback
        description: Cashback details for provider. Populated when the affiliate supports cashback.
    example:
      code: BOOKINGDOTCOMAFFILIATE
      name: Booking.com
      logo: "https://content.r9cdn.net/rimg/provider-logos/hotels/h/BOOKINGDOTCOM.png?crop=false&width=88&height=31&fallback=default2.png&_v=1233faf051a0a6b9d9807846b1316f74"
      isDirect: false
      isLanguageSupported: true
  ProviderCashback:
    type: object
    description: Cashback configuration details for a booking option.
    properties:
      type:
        type: string
        description: Type of cashback (e.g., percentage, fixed amount).
        enum: [ "PERCENTAGE", "FLAT" ]
      value:
        type: number
        format: double
        description: Cashback value (percentage or fixed amount).
      cap?:
        type: number
        format: double
        description: Maximum cashback cap, if applicable.
      currency:
        type: CurrencyCode
        description: Currency code for the cashback amount and cap.
  SortField:
    type: string
    description: Field to use for sorting the results
    enum: [ consumerRating, distance, name, minRate, popularity, rating ]
  SortDirection:
    type: string
    description: Direction to use for sorting the results
    enum: [ ascending, descending ]
  PipeDelimitedIntegerList:
    type: string
    description: Pipe-delimited list of integers
    example: 1|2|3|4
  CurrencyCode:
    type: string
    pattern: "[A-Z]{3}"
    description: |
      ISO 4217 code identifier for currency. 
      Currency codes are composed of a country's two-character Internet country code plus a third character denoting the currency unit
    example: USD
  LanguageCode:
    type: string
    pattern: "[A-Z]{2}"
    description: ISO 639 code identifier for language
    example: DE
  CountryCode:
    type: string
    pattern: "[A-Z]{2}"
    description: ISO 3166 code identifier for country
    example: KR
  InclusionType:
    type: number
    minimum: 0
    maximum: 4
    description: |
        Inclusion type. The value is used to determine the type of inclusion.
        
        0 - Breakfast included
        1 - Lunch included
        2 - Dinner included
        3 - Meals included
        4 - All inclusive
  HotelResult:
    type: object
    description: Hotel search result details
    properties:
      id:
        type: number
        description: Unique identifier for the hotel
      key:
        type: EntityKey
        description: Hotel key
      name:
        type: string
        description: Hotel name
      address:
        type: string
        description: Hotel address
      hotelCountryCode:
        type: CountryCode
        description: Country code for the hotel's country
      latitude:
        type: number
        format: double
        description: Latitude of the hotel's location
      longitude:
        type: number
        format: double
        description: Longitude of the hotel's location
      starRating:
        type: number
        description: Hotel star rating
      isSelfRated:
        type: boolean
        description: Indicates whether the hotel is self-rated
      lowestRate:
        type: number | nil
        description: Lowest rate available for the hotel
      href:
        type: string
        description: Absolute URL to this hotel's search
      distance:
        type: number
        description: |
          Distance from the search location to the hotel. 
          
          kpolygon - distance is calculated from hotel to polygon center;
          klatlon - distance is calculated from hotel to lat/lon;
          kplace - distance is calculated from hotel to given place;
          khotels, khotel - distance is not set;
      isWithinBoundary:
        type: boolean
        description: Indicates whether the hotel is within the search boundary. Always false.
      isGreatValue:
        type: boolean
        description: |
          Indicates whether the hotel is considered a great value. It's true if any of the booking options have
          custom rate (e.g, mobile rate or desktop rate only), is under priced or opaque.
      propertyType:
        type: number
        description: Property type
      numberOfProviders:
        type: number
        description: Number of providers offering rates for the hotel
      numberOfRates:
        type: number
        description: Number of rates available for the hotel
      guestRating:
        type: number
        description: Hotel guest rating
      numberOfReviews:
        type: number
        description: Number of reviews for the hotel
      highestRate:
        type: number | nil
        description: Highest rate available for the hotel
      licenseNumber?:
        type: string
        description: License number for the property
      rates?:
        type: HotelRate[]
        description: |
          Rates for the hotel.
          Booking options are returned sorted based on our recommendations to provide the most relevant options first.
          Optionally included by passing `topRates` or `multipleHotelsAllRates` value to the `responseOptions` parameter
      wellKnownPlace?:
        type: HotelPlace
        description: |
          Well-known place information that the hotel belongs to.

          Optionally included by passing `hotelWellKnownPlace` value to the `responseOptions` parameter
      images?:
        type: HotelImage[]
        description: |
          Hotel images.
          
          Optionally included by passing `images` value to the `responseOptions` parameter
      place?:
        type: HotelPlace
        description: |
          Hotel place information.
          
          Optionally included by passing `hotelPlace` value to the `responseOptions` parameter
      reviewQuotes?:
        type: string[]
        description: |
          List of quotes from reviews
          
          Optionally included by passing `reviews` value to the `responseOptions` parameter
      guestRatingSentiment?:
        type: string
        description: |
          Guest rating sentiment.
          
          Optionally included by passing `reviews` value to the `responseOptions` parameter
    example:
      id: 2589314
      key: khotel:2589314
      name: citizenM Tower of London
      address: 40 Trinity Square
      hotelCountryCode: GB
      latitude: 51.51018
      longitude: -0.07687
      starRating: 4
      isSelfRated: false
      images:
        - large: "https://www.kayak.ch/h/run/api/image?url=/himg/c7/00/32/expedia_group-2589314-56e9e3-056459.jpg&maxheight=460"
          small: "https://www.kayak.ch/h/run/api/image?url=/himg/c7/00/32/expedia_group-2589314-56e9e3-056459.jpg&maxheight=230"
      lowestRate: 1213.11
      href: "https://sandbox-en-us.kayakaffiliates.com/api/3.0/hotel?apiKey=key&checkin=2025-01-01&checkout=2025-01-10&rooms=2&pageSize=2&responseOptions=toprates%2Cimages&userTrackId=trackId&pageSize=1&hotel=khotel%3A2589314"
      distance: 0
      isWithinBoundary: false
      isGreatValue: false
      propertyType: 0
      numberOfProviders: 4
      numberOfRates: 7
      guestRating: 8.6
      numberOfReviews: 3118
      highestRate: 1429.74
      rates:
        - roomName: King-Zimmer
          totalRate: 1215.27
          isCheapestRate: false
          hasFreeCancellation: false
          canPayLater: false
          isBundledRate: false
          inclusions: [ ]
          availableRooms: 10
          providerIndex: 1
          isDeprioritisedForExcludedCharges: false
          bookUri: "https://sandbox-en-us.kayakaffiliates.com/in?cluster=5&a=kan_316089_592117&p=&cc=ch&mc=CHF&lc=EN&url=%2Fbook%2Fhotel%3Fcode%3DeXGkEkc2O2.xpBwLNU05piWyuc3AtCaFCQNXgtXYvS8.18445.2589314.MTczNTcwNzYwMDAwMF4xNzM2NDg1MjAwMDAwXjFeMl4%3D%26h%3D33a771566190%26sub%3D0%26_pt_%3D1&utid=YXF3ZGFhd2Rhd2RhYWRhYWF3ZGRhZHc%3D&cookieOverrides=e0r-vV17CTyHTY65FOuSfpGlZ8VuTtLg-vwvRhe5-avqm932KtEVJZiOo4bVrFuActUOcDgSrhkWgKBlk9DiUyyEqfs91OQwgBw-4svw-cD8_AUUTgde4st6JYeA6J64Coj0sGlwD5WqQy_UFPcgjCumX55wHwwOVU87k42BgPs"
  BasicHotelResult:
    type: object
    properties:
      id:
        type: number
        description: Unique identifier for the hotel
      key:
        type: EntityKey
        description: Unique key for the hotel
      name:
        type: string
        description: Name of the hotel
      latitude:
        type: number
        format: double
        description: Latitude of the hotel's location
      longitude:
        type: number
        format: double
        description: Longitude of the hotel's location
      starRating:
        type: number
        description: Star rating of the hotel
      isSelfRated:
        type: boolean
        description: Indicates whether the hotel is self-rated
      lowestRate:
        type: number | nil
        description: Lowest rate available for the hotel
      href:
        type: string
        description: Absolute URL to this hotel's search
      guestRating:
        type: number
        description: Guest rating of the hotel
      numberOfReviews:
        type: number
        description: Number of reviews for the hotel
      highestRate:
        type: number | nil
        description: Highest rate available for the hotel
      image:
        type: object
        properties:
          large:
            type: string
            description: URL of the large image
        description: Hotel image
      licenseNumber?:
        type: string
        description: License number for the property
    example:
